[
  {
    "name": "theme_info",
    "theme_name": "Theme Builder Base",
    "theme_author": "shopify-theme-builder",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://shopify.dev/docs/themes",
    "theme_support_url": "https://shopify.dev/docs/themes"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "default": "#ffffff",
            "label": "Background"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Background gradient",
            "info": "Overrides the solid background when set."
          },
          {
            "type": "color",
            "id": "text",
            "default": "#14110f",
            "label": "Text"
          },
          {
            "type": "color",
            "id": "primary_button",
            "default": "#14110f",
            "label": "Primary button / accent"
          },
          {
            "type": "color",
            "id": "on_primary_button",
            "default": "#ffffff",
            "label": "Text on primary button"
          },
          {
            "type": "color",
            "id": "secondary_button",
            "default": "#ffffff",
            "label": "Secondary button"
          },
          {
            "type": "color",
            "id": "on_secondary_button",
            "default": "#14110f",
            "label": "Text on secondary button"
          },
          {
            "type": "color",
            "id": "border",
            "default": "#e3ded8",
            "label": "Border"
          },
          {
            "type": "color",
            "id": "surface",
            "default": "#f7f4f0",
            "label": "Surface / card"
          },
          {
            "type": "color",
            "id": "secondary",
            "default": "#6b6560",
            "label": "Secondary text"
          },
          {
            "type": "color",
            "id": "accent",
            "default": "#8a6d3b",
            "label": "Accent"
          },
          {
            "type": "color",
            "id": "sale",
            "default": "#b23b3b",
            "label": "Sale / price"
          }
        ],
        "role": {
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "text": "text",
          "primary_button": "primary_button",
          "on_primary_button": "on_primary_button",
          "primary_button_border": "primary_button",
          "secondary_button": "secondary_button",
          "on_secondary_button": "on_secondary_button",
          "secondary_button_border": "border",
          "links": "primary_button",
          "icons": "text",
          "shadow": "text"
        }
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "default": "assistant_n4",
        "label": "Heading font"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading size scale",
        "default": 115
      },
      {
        "type": "select",
        "id": "heading_transform",
        "label": "Heading letter case",
        "options": [
          { "value": "none", "label": "Default" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "lowercase", "label": "Lowercase" }
        ],
        "default": "none"
      },
      {
        "type": "header",
        "content": "Body"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "assistant_n4",
        "label": "Body font"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 90,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "Base body size",
        "default": 100
      }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "Used in the header and footer."
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 240,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Shown in the browser tab. 32 x 32px recommended."
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1300
      },
      {
        "type": "range",
        "id": "section_spacing",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "label": "Vertical space between sections",
        "default": 64
      },
      {
        "type": "range",
        "id": "grid_gap",
        "min": 8,
        "max": 48,
        "step": 2,
        "unit": "px",
        "label": "Grid gap",
        "default": 24
      },
      {
        "type": "range",
        "id": "page_margin",
        "min": 12,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Side page margin (mobile)",
        "default": 20
      }
    ]
  },
  {
    "name": "Corners",
    "settings": [
      {
        "type": "range",
        "id": "radius_sm",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Small radius (inputs, chips)",
        "default": 6
      },
      {
        "type": "range",
        "id": "radius_md",
        "min": 0,
        "max": 32,
        "step": 1,
        "unit": "px",
        "label": "Medium radius (cards, buttons)",
        "default": 10
      },
      {
        "type": "range",
        "id": "radius_lg",
        "min": 0,
        "max": 48,
        "step": 1,
        "unit": "px",
        "label": "Large radius (media, modals)",
        "default": 20
      }
    ]
  },
  {
    "name": "Shadows",
    "settings": [
      {
        "type": "range",
        "id": "shadow_opacity",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "%",
        "label": "Shadow strength",
        "default": 12
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "button_radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "Button radius",
        "default": 10
      },
      {
        "type": "range",
        "id": "button_border_width",
        "min": 0,
        "max": 4,
        "step": 1,
        "unit": "px",
        "label": "Button border width",
        "default": 1
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "animations_enabled",
        "label": "Enable reveal-on-scroll animations",
        "default": true
      },
      {
        "type": "select",
        "id": "animation_speed",
        "label": "Animation speed",
        "options": [
          { "value": "fast", "label": "Fast" },
          { "value": "base", "label": "Standard" },
          { "value": "slow", "label": "Relaxed" }
        ],
        "default": "base"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Slide-out drawer" },
          { "value": "page", "label": "Full page" }
        ],
        "default": "drawer"
      }
    ]
  }
]
