{%- comment -%}
  main-password.liquid — storefront password page content.
{%- endcomment -%}
<div class="main-password color-{{ section.settings.color_scheme }}">
  <div class="main-password__inner page-width section">
    <h1 class="main-password__shop-name">{{ shop.name }}</h1>
    {%- if shop.password_message != blank -%}
      <div class="main-password__message rte">{{ shop.password_message }}</div>
    {%- endif -%}

    {%- form 'storefront_password', class: 'main-password__form' -%}
      {%- if form.errors -%}
        <p class="main-password__error">{{ 'sections.password.error' | t }}</p>
      {%- endif -%}
      <label class="visually-hidden" for="PasswordInput">{{ 'sections.password.label' | t }}</label>
      <input
        id="PasswordInput"
        type="password"
        name="password"
        class="main-password__input"
        placeholder="{{ 'sections.password.placeholder' | t }}"
        autocomplete="current-password"
      >
      <button type="submit" class="button">{{ 'sections.password.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>

{%- style -%}
  .main-password__inner { display: grid; gap: var(--space-4); justify-items: center; text-align: center; max-width: 480px; }
  .main-password__form { display: grid; gap: var(--space-3); width: 100%; }
  .main-password__input {
    padding: var(--space-3) var(--space-4);
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-sm);
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
