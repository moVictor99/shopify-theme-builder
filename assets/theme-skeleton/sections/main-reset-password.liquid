{%- comment -%}
  main-reset-password.liquid — set a new password via reset link.
{%- endcomment -%}
<div class="main-reset color-{{ section.settings.color_scheme }}">
  <div class="main-reset__inner page-width section">
    <h1 class="main-reset__title">{{ 'customer.reset_password.title' | t }}</h1>
    <p>{{ 'customer.reset_password.subtext' | t }}</p>

    {%- form 'reset_customer_password', class: 'main-reset__form' -%}
      {%- if form.errors -%}
        <ul class="form__errors" role="list">
          {%- for field in form.errors -%}
            <li>{{ form.errors.messages[field] }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      <label for="ResetPassword">{{ 'customer.reset_password.password' | t }}</label>
      <input id="ResetPassword" type="password" name="customer[password]" autocomplete="new-password" required>

      <label for="ResetPasswordConfirm">{{ 'customer.reset_password.password_confirm' | t }}</label>
      <input id="ResetPasswordConfirm" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>

      <button type="submit" class="button">{{ 'customer.reset_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>

{%- style -%}
  .main-reset__inner { max-width: 480px; display: grid; gap: var(--space-4); }
  .main-reset__form { display: grid; gap: var(--space-3); }
  .main-reset__form input {
    padding: var(--space-3) var(--space-4);
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--radius-sm);
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Reset password",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
