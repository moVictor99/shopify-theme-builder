<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  dir="{% if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' or request.locale.iso_code == 'fa' or request.locale.iso_code == 'ur' %}rtl{% else %}ltr{% endif %}"
>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_schemes.scheme-1.settings.background }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>{{ 'gift_cards.issued.title' | t }} &ndash; {{ shop.name }}</title>
    {% render 'css-variables' %}
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="template-gift-card color-scheme-1">
    <main id="MainContent" role="main" class="gift-card page-width section" tabindex="-1">
      <h1 class="gift-card__title">{{ 'gift_cards.issued.title' | t }}</h1>
      <p class="gift-card__subtitle">{{ 'gift_cards.issued.subtext' | t: shop: shop.name }}</p>

      <p class="gift-card__balance">
        {{ 'gift_cards.issued.balance' | t }}:
        <strong>{{ gift_card.balance | money }}</strong>
      </p>

      {%- comment -%}
        Shopify has NO server-side filter that turns gift_card.qr_identifier into a
        QR image — `payment_icon_png_url` (a common copy-paste) is not a real filter
        and fails theme-check (reliability-and-sync.md §12). To show a scannable QR,
        bundle a QR library in assets/ and render it client-side from
        `gift_card.qr_identifier` (see Dawn's gift_card.liquid). The printed code
        below is the reliable, dependency-free redemption path.
      {%- endcomment -%}

      <p class="gift-card__code">
        {{ 'gift_cards.issued.code' | t }}:
        <strong>{{ gift_card.code | format_code }}</strong>
      </p>

      <a href="{{ shop.url }}" class="button">{{ 'gift_cards.issued.shop_link' | t }}</a>
    </main>
  </body>
</html>

{%- style -%}
  .gift-card { display: grid; gap: var(--space-4); justify-items: center; text-align: center; max-width: 480px; margin-inline: auto; }
  .gift-card__balance { font-size: var(--font-h3); }
{%- endstyle -%}
